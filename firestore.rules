rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Hanya izinkan baca & tulis pada koleksi qc_entries.
    // Tidak perlu login (cocok untuk pemakaian internal tim via link).
    // Validasi dasar memastikan field wajib terisi dengan tipe yang benar.
    match /qc_entries/{entryId} {
      allow read: if true;

      allow create: if
        request.resource.data.outlet is string &&
        request.resource.data.tanggal is string &&
        request.resource.data.shift is string &&
        request.resource.data.checker is string &&
        request.resource.data.rasa is number &&
        request.resource.data.porsi is number &&
        request.resource.data.presentasi is number &&
        request.resource.data.kebersihan is number &&
        request.resource.data.suhu is number;

      allow update: if false;
      allow delete: if request.auth != null;
    }

    // Blokir semua koleksi lain secara default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
